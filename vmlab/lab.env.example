# Kopyala:  cp lab.env.example lab.env  ve değerleri doldur.
# Tüm vmlab/*.sh bu dosyayı bulmak için: script dizini + üst ../lab.env
# Veya:  export VMLAB_ENV=/path/to/lab.env

# Sanal ağ (ör. VirtualBox/VMware Host-Only, libvirt, VLAN)
# Kurban: GhostCatcher + nginx + php + ssh
# Saldıran: Kali
export VICTIM_IP=192.168.56.10
export ATTACKER_IP=192.168.56.20

# İsim çözümlemesi (Kali /etc/hosts ve curl için)
export VICTIM_HOSTNAME=victim.lab

# (İsteğe bağlı) SIEM — kurban makinede ajan bu adreslere log iter
# Ayrı sunucudaysa: http://192.168.56.1:3100
export SIEM_LOKI_URL=""
# Boş bırakılırsa ghostcatcher-lab.config.yaml sink'leri kapatır (yalnızca stdout)
export SIEM_SYSLOG_HOST=""
export SIEM_SYSLOG_UDP_PORT=5514

# Go kaynak: install-victim.sh buradan ghostcatcher derler
# Boş: script kendi yolunu (repo kökü) keşfeder
export GHOSTCATCHER_REPO=""

# Kali kurduktan sonra: victim’te install-victim’i bu satırla tekrar çalıştırın veya root authorized_keys’e manuel:
#   export KALI_SSH_PUB_KEY_LINE="ssh-ed25519 AAAA... kali@lab"
# veya: KALI_SSH_PUB=$HOME/.config/ghostcatcher-lab/ssh/id_ed25519.pub
export KALI_SSH_PUB_KEY_LINE=""
export KALI_SSH_PUB=""
