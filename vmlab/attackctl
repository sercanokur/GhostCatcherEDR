#!/bin/sh
# vmlab — kurban sunucu (PATH: /usr/local/bin/attackctl)
set -e
GC=/usr/local/bin/ghostcatcher
CFG=/etc/ghostcatcher/lab.config.yaml
SCEN=/opt/lab/scenarios

usage() {
	echo "Kullanım: attackctl <list|apply <ad>|reset|baseline|scan|check>"
	echo "Tek sh:  sudo sh /opt/lab/scenarios/web-shell.sh  (tarama: GCLAB_RUN_SCAN=1 veya sonda scan)"
}

case "${1:-}" in
list)
	for f in "$SCEN"/*.sh; do
		[ -f "$f" ] || continue
		b=$(basename "$f" .sh)
		echo "  - $b"
	done
	;;
apply)
	if [ -z "$2" ]; then usage; exit 1; fi
	script="$SCEN/${2}.sh"
	if [ ! -f "$script" ]; then
		echo "Senaryo yok: $2" >&2
		exit 1
	fi
	sh "$script"
	echo "Uygulandı: $2"
	;;
reset)
	sh /opt/lab/reset-lab.sh
	;;
baseline)
	"$GC" baseline commit -config "$CFG"
	;;
scan|run-once)
	"$GC" run -config "$CFG" -once
	;;
check|check-config)
	"$GC" check-config -config "$CFG"
	;;
""|-h|--help|help)
	usage
	;;
*)
	usage
	exit 1
	;;
esac
